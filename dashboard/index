    background: #0a0f1e;
    color: #e2e8f0;
    min-height: 100vh;
    padding: 2rem;
  }

  .container { max-width: 980px; margin: 0 auto; }

  header {
    border-bottom: 1px solid #1e3a5f;
    padding-bottom: 1.5rem;
    margin-bottom: 2rem;
  }
  header .eyebrow {
    color: #38bdf8;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 0.4rem;
  }
  header h1 {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    color: #f0f9ff;
  }
  header p { color: #64748b; font-size: 0.85rem; margin-top: 0.3rem; }

  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .card {
    background: #0f1f3d;
    border: 1px solid #1e3a5f;
    border-radius: 8px;
    padding: 1.2rem;
  }
  .card .label {
    color: #38bdf8;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .card .value {
    font-family: 'Playfair Display', serif;
    font-size: 1.7rem;
    color: #f0f9ff;
    margin-top: 0.3rem;
  }

  .toggle {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.2rem;
  }
  .toggle button {
    padding: 0.4rem 1.1rem;
    border-radius: 4px;
    border: 1px solid #1e3a5f;
    background: #0f1f3d;
    color: #94a3b8;
    cursor: pointer;
    font-size: 0.8rem;
    font-family: 'Source Sans 3', sans-serif;
    transition: all 0.2s;
  }
  .toggle button.active {
    background: #0ea5e9;
    color: #fff;
    border-color: #0ea5e9;
  }

  .chart-box {
    background: #0f1f3d;
    border: 1px solid #1e3a5f;
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .chart-box h2 {
    color: #38bdf8;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 1.2rem;
    font-weight: 600;
  }

  .click-hint {
    color: #475569;
    font-size: 0.72rem;
    margin-bottom: 1rem;
    font-style: italic;
  }

  .bottom-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .pie-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }
  .pie-legend span {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 0.7rem;
    color: #94a3b8;
  }
  .dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    display: inline-block;
    flex-shrink: 0;
  }

  table { width: 100%; border-collapse: collapse; font-size: 0.78rem; }
  thead tr { border-bottom: 1px solid #1e3a5f; }
  th { color: #38bdf8; font-weight: 400; padding-bottom: 6px; }
  th:first-child { text-align: left; }
  th:not(:first-child) { text-align: right; }
  td { padding: 5px 0; border-bottom: 1px solid #0a1628; vertical-align: middle; }
  td:not(:first-child) { text-align: right; }
  .flag-cell { display: flex; align-items: center; gap: 7px; }
  .td-calls { color: #f0f9ff; }
  .td-vessels { color: #64748b; }

  .scroll-table { overflow-y: auto; max-height: 300px; }

  /* Modal */
  .modal-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.75);
    z-index: 100;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }
  .modal-backdrop.open { display: flex; }

  .modal {
    background: #0f1f3d;
    border: 1px solid #1e3a5f;
    border-radius: 12px;
    width: 100%;
    max-width: 640px;
    max-height: 80vh;
    display: flex;
    flex-direction: column;
    animation: slideUp 0.2s ease;
  }
  @keyframes slideUp {
    from { transform: translateY(20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  .modal-header {
    padding: 1.5rem 1.5rem 1rem;
    border-bottom: 1px solid #1e3a5f;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }
  .modal-header .flag-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem;
    color: #f0f9ff;
  }
  .modal-header .meta {
    color: #64748b;
    font-size: 0.8rem;
    margin-top: 0.2rem;
  }
  .modal-close {
    background: none;
    border: 1px solid #1e3a5f;
    color: #64748b;
    cursor: pointer;
    border-radius: 4px;
    padding: 0.3rem 0.6rem;
    font-size: 1rem;
    transition: all 0.15s;
    line-height: 1;
    flex-shrink: 0;
  }
  .modal-close:hover { border-color: #38bdf8; color: #38bdf8; }

  .modal-body {
    overflow-y: auto;
    padding: 1.2rem 1.5rem 1.5rem;
