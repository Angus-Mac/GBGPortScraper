        titleColor: '#38bdf8', bodyColor: '#e2e8f0',
      }
    }
  }
});

// Pie legend
const legendEl = document.getElementById('pie-legend');
pieLabels.forEach((f, i) => {
  const span = document.createElement('span');
  span.innerHTML = `<span class="dot" style="background:${i<6?COLORS[i]:'#1e3a5f'}"></span>${f}`;
  legendEl.appendChild(span);
});

// ── Flag Table ─────────────────────────────────────────────
const tbody = document.getElementById('table-body');
flagData.forEach(({ flag, calls, vessels }, i) => {
  const tr = document.createElement('tr');
  tr.style.cursor = 'pointer';
  tr.innerHTML = `
    <td><div class="flag-cell"><span class="dot" style="background:${COLORS[i]}"></span>${flag}</div></td>
    <td class="td-calls">${calls}</td>
    <td class="td-vessels">${vessels}</td>
  `;
  tr.addEventListener('click', () => openModal(flag));
  tr.addEventListener('mouseenter', () => tr.style.background = '#12284a');
  tr.addEventListener('mouseleave', () => tr.style.background = '');
  tbody.appendChild(tr);
});

// ── Toggle ─────────────────────────────────────────────────
function switchMetric(m) {
  metric = m;
  document.getElementById('btn-calls').classList.toggle('active', m === 'calls');
  document.getElementById('btn-vessels').classList.toggle('active', m === 'vessels');
  document.getElementById('bar-title').textContent = m === 'calls' ? 'Port Calls per Flag' : 'Unique Vessels per Flag';
  barChart.data.datasets[0].data = flagData.map(d => d[m]);
  barChart.update();
}

// ── Modal ──────────────────────────────────────────────────
function openModal(flagName) {
  const vessels = getVessels(flagName);
  document.getElementById('modal-flag-name').textContent = flagName;

  const totalCalls = vessels.reduce((s, v) => s + v.calls, 0);
  document.getElementById('modal-meta').textContent =
    `${vessels.length} vessel${vessels.length !== 1 ? 's' : ''} · ${totalCalls} port call${totalCalls !== 1 ? 's' : ''}`;

  const maxCalls = Math.max(...vessels.map(v => v.calls));
  const mtbody = document.getElementById('modal-table-body');
  mtbody.innerHTML = '';

  vessels.forEach(v => {
    const tr = document.createElement('tr');
    const imoDisplay = v.imo && v.imo > 0 ? v.imo : '—';
    const pct = (v.calls / maxCalls) * 100;
    tr.innerHTML = `
      <td>
        <div class="vessel-name">${v.name}</div>
        <div class="bar-row">
          <div class="bar-track"><div class="bar-fill" style="width:${pct}%"></div></div>
        </div>
      </td>
      <td class="imo">${imoDisplay}</td>
      <td>${v.calls}</td>
    `;
    mtbody.appendChild(tr);
  });

  document.getElementById('modal-backdrop').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeModal() {
  document.getElementById('modal-backdrop').classList.remove('open');
  document.body.style.overflow = '';
}

function closeModalOnBackdrop(e) {
  if (e.target === document.getElementById('modal-backdrop')) closeModal();
}

document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
</script>
</body>
</html>
