  .modal-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
  .modal-table thead tr { border-bottom: 1px solid #1e3a5f; }
  .modal-table th { color: #38bdf8; font-weight: 400; padding: 0 0 8px; text-align: left; }
  .modal-table th:last-child { text-align: right; }
  .modal-table td { padding: 7px 0; border-bottom: 1px solid #0a1628; color: #e2e8f0; vertical-align: middle; }
  .modal-table td:last-child { text-align: right; color: #f0f9ff; }
  .modal-table td.imo { color: #64748b; font-family: monospace; font-size: 0.8rem; }
  .vessel-name { font-weight: 600; color: #f0f9ff; }

  .bar-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 2px;
  }
  .bar-track {
    flex: 1;
    background: #1e3a5f;
    border-radius: 2px;
    height: 4px;
    overflow: hidden;
  }
  .bar-fill {
    height: 100%;
    border-radius: 2px;
    background: #0ea5e9;
  }
  .bar-label { color: #64748b; font-size: 0.75rem; min-width: 20px; text-align: right; }
</style>
</head>
